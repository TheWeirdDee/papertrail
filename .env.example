# STACKS NETWORK CONFIGURATION
# Options: testnet, mainnet
NEXT_PUBLIC_STACKS_NETWORK=mainnet

# SMART CONTRACT CONFIGURATION
# Deployer wallet address
NEXT_PUBLIC_CONTRACT_ADDRESS=SP2WKK2W5DR70D2YCHHBEF7R5EMK5NZNQE2Z8T3EF
# Contract name on mainnet
# NEXT_PUBLIC_CONTRACT_NAME is not used directly - name is hardcoded in src/lib/config.ts

# APP URLS
NEXT_PUBLIC_APP_URL=https://papertrail.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# SUPABASE CONFIGURATION
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AUTH & SECURITY
LOCAL_SESSION_SECRET=your-secret-here
